{
  "name": "delegate-team",
  "version": "2.4.0",
  "description": "Agentic engineering supersystem. One CLI to run the full /mavis-ship chain — design + plan + execute (autoresearch / multi-model / multi-agent) + verify + ship. Bundles a `dt` delegation gateway that routes Claude Code tasks to backends (Codex, MiniMax via mmx, Gemini, MetaGPT), plus a complete orchestrator framework installable via `npx skills add`. Companion frameworks: superpowers, Waza, unslop-preflight, autoresearch.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "dt": "dist/cli.js",
    "delegate-team": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "size": "npm pack --dry-run",
    "publish:dry": "npm publish --dry-run --access public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "keywords": [
    "delegate-team",
    "mavis-ship",
    "ai",
    "agent",
    "agents",
    "agentic-engineering",
    "multi-agent",
    "orchestration",
    "mmas",
    "cli",
    "delegation",
    "skills",
    "skills-sh",
    "autoresearch",
    "superpowers",
    "waza",
    "unslop",
    "claude-code",
    "codex",
    "cursor",
    "minimax",
    "mmx",
    "vertex",
    "gemini",
    "metagpt",
    "llm",
    "routing",
    "mcp"
  ],
  "author": {
    "name": "Mamdouh Aboammar",
    "email": "mamdouhfces1997@gmail.com",
    "url": "https://github.com/imMamdouhaboammar"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/imMamdouhaboammar/delegate-team/issues"
  },
  "homepage": "https://github.com/imMamdouhaboammar/delegate-team#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imMamdouhaboammar/delegate-team.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "commander": "^15.0.0"
  }
}
